# Database (Postgres or MongoDB)
DATABASE_URI=postgres://user:password@127.0.0.1:5432/your-database-name

# Payload
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (used for absolute URLs, image loader, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ISR Revalidation (secret shared with Payload revalidation hooks)
REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE

# Resend (transactional email — contact form). Use a key scoped to the sending domain only.
RESEND_TOKEN=re_YOUR_RESEND_KEY_HERE

# Cloudflare Turnstile (anti-bot on the contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Third-party generation APIs (admin-only)
FORVOYEZ_TOKEN=YOUR_FORVOYEZ_TOKEN
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# S3 / Cloudflare R2 storage
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
